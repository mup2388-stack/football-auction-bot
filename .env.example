# ============================================================
#  Football Auction Bot — configuration (.env)
#  Copy this file to ".env" and fill in your bot token.
# ============================================================

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=put-your-bot-token-here

# Comma-separated list of Discord user IDs who can run admin commands.
# (Right-click a user -> Copy ID, with Developer Mode enabled in Discord.)
# Example: 111111111111111111,222222222222222222
ADMIN_IDS=

# The bot prefix for legacy text commands (slash commands are primary).
PREFIX=!

# Virtual currency shown to users (£ by default).
CURRENCY_SYMBOL=£
CURRENCY_NAME=coins
